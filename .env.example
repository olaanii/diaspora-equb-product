# ─────────────────────────────────────────────────────
#  Diaspora Equb — Single .env (root of project)
#  Copy to .env and fill in real values
# ─────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=equb
DATABASE_PASSWORD=change_me
DATABASE_NAME=diaspora_equb
# Set to true for hosted Postgres providers that require TLS (Neon, Supabase, Render, etc.)
DATABASE_SSL=false

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=change_me_to_a_secure_random_string
JWT_EXPIRATION=1d

# ── Fayda Identity ────────────────────────────────────
FAYDA_API_URL=https://api.fayda.et/v1
FAYDA_API_KEY=change_me

# ── Blockchain (Creditcoin) ──────────────────────────
# ┌────────────┬────────────────────────────────────────────────┬────────┐
# │ Network    │ RPC URL                                        │ Chain  │
# ├────────────┼────────────────────────────────────────────────┼────────┤
# │ Testnet    │ https://rpc.cc3-testnet.creditcoin.network     │ 102031 │
# │ Mainnet    │ https://mainnet3.creditcoin.network            │ 102030 │
# └────────────┴────────────────────────────────────────────────┴────────┘
# Testnet Explorer: https://creditcoin-testnet.blockscout.com
# Mainnet Explorer: https://creditcoin.blockscout.com
# Optional: override for transaction history (defaults by CHAIN_ID)
# BLOCKSCOUT_API_URL=https://creditcoin-testnet.blockscout.com/api
# Testnet Faucet:   Creditcoin Discord #token-faucet → /faucet address:YOUR_ADDRESS
RPC_URL=https://rpc.cc3-testnet.creditcoin.network
CHAIN_ID=102031

# ── Core Contract Addresses (after: cd contracts && npm run deploy:creditcoin-testnet)
IDENTITY_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
TIER_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
CREDIT_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
COLLATERAL_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
PAYOUT_STREAM_ADDRESS=0x0000000000000000000000000000000000000000
EQUB_POOL_ADDRESS=0x0000000000000000000000000000000000000000

# ── Test Token Addresses (after: cd contracts && npm run deploy:test-tokens)
TEST_USDC_ADDRESS=0x0000000000000000000000000000000000000000
TEST_USDT_ADDRESS=0x0000000000000000000000000000000000000000

# ── Transaction history (optional) ────────────────────
# Block lookback for on-chain TX history (Creditcoin testnet). Default 1000000.
# TX_HISTORY_LOOKBACK_BLOCKS=1000000

# ── Backend Server ────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS (production only) ───────────────────────────
# Comma-separated allowed origins for production CORS policy.
# In development all origins are allowed.
CORS_ORIGINS=https://app.diaspora-equb.com

# ── Sentry Error Tracking (optional) ──────────────
# Get a DSN at https://sentry.io → Create Project → Node.js / Flutter
# Leave empty to disable Sentry.
SENTRY_DSN=

# ── Deployer Private Key (used by contracts/ only, never by backend)
# Export from MetaMask → Account details → Show private key
DEPLOYER_PRIVATE_KEY=0xYOUR_64_HEX_CHAR_PRIVATE_KEY_HERE

# ── WalletConnect (Flutter app — pass via --dart-define when running)
# Get a project ID at https://cloud.walletconnect.com (free)
# Run: flutter run --dart-define=WALLETCONNECT_PROJECT_ID=your_project_id
# Optional: API_BASE_URL, RPC_URL, CHAIN_ID (default: Creditcoin Testnet 102031)
WALLETCONNECT_PROJECT_ID=

# ── Firebase Auth (Frontend web/mobile via --dart-define, Backend via env) ──
# Frontend: use values from Firebase Console → Project settings → General → Your apps.
# Web app values feed browser auth.
# Android app values feed Android auth. Current package name in this repo:
# com.example.diaspora_equb_frontend
# Example web run command:
# flutter run -d chrome \
#   --dart-define=FIREBASE_API_KEY=your_api_key \
#   --dart-define=FIREBASE_APP_ID=your_app_id \
#   --dart-define=FIREBASE_MESSAGING_SENDER_ID=your_sender_id \
#   --dart-define=FIREBASE_PROJECT_ID=your_project_id \
#   --dart-define=FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com \
#   --dart-define=FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app \
#   --dart-define=FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX \
#   --dart-define=GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
# Example Android emulator run command:
# flutter run -d android \
#   --dart-define=API_BASE_URL=http://10.0.2.2:3001/api \
#   --dart-define=FIREBASE_API_KEY=your_api_key \
#   --dart-define=FIREBASE_APP_ID=your_android_app_id \
#   --dart-define=FIREBASE_MESSAGING_SENDER_ID=your_sender_id \
#   --dart-define=FIREBASE_PROJECT_ID=your_project_id \
#   --dart-define=FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app \
#   --dart-define=FIREBASE_ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com \
#   --dart-define=GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_PROJECT_ID=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MEASUREMENT_ID=
GOOGLE_WEB_CLIENT_ID=

# Native client IDs for mobile/desktop Firebase Google sign-in.
# Android uses FIREBASE_ANDROID_CLIENT_ID together with GOOGLE_WEB_CLIENT_ID.
FIREBASE_ANDROID_CLIENT_ID=
FIREBASE_IOS_CLIENT_ID=
FIREBASE_IOS_BUNDLE_ID=

# Backend Firebase Admin values: use a service account from
# Firebase Console → Project settings → Service accounts.
# The backend already reads these from the root .env file when you run:
#   cd backend
#   npm run start:dev
# Use these same keys in Vercel project environment variables for redeploys.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
