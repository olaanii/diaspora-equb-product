# ============================================================
# Diaspora Equb DeFi — Production Environment
# ============================================================
# Copy to .env and fill in real values before deploying.
# NEVER commit .env with real secrets to version control.
# ============================================================

NODE_ENV=production

# ─── Database ───────────────────────────────────────────────
DATABASE_HOST=your-db-host
DATABASE_PORT=5432
DATABASE_USERNAME=equb_prod
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_NAME=diaspora_equb_prod

# ─── Creditcoin Mainnet ────────────────────────────────────
RPC_URL=https://mainnet-rpc.creditcoin.org
CHAIN_ID=102030

# ─── Contract Addresses (mainnet — deploy with deploy-upgradeable.ts) ──
IDENTITY_REGISTRY_ADDRESS=0x...
TIER_REGISTRY_ADDRESS=0x...
CREDIT_REGISTRY_ADDRESS=0x...
COLLATERAL_VAULT_ADDRESS=0x...
PAYOUT_STREAM_ADDRESS=0x...
EQUB_POOL_ADDRESS=0x...
EQUB_GOVERNOR_ADDRESS=0x...
SWAP_ROUTER_ADDRESS=0x...
ACHIEVEMENT_BADGE_ADDRESS=0x...

# ─── Token Addresses (real mainnet tokens, NOT test tokens) ─
TEST_USDC_ADDRESS=0x...
TEST_USDT_ADDRESS=0x...

# ─── Authentication ────────────────────────────────────────
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
JWT_EXPIRATION=24h

# ─── Fayda National ID API (production credentials) ───────
FAYDA_API_URL=https://api.fayda.et
FAYDA_API_KEY=your-production-key

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── CORS (restrict to production frontend only) ──────────
CORS_ORIGIN=https://your-app.vercel.app

# ─── Monitoring ────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn
LOG_LEVEL=warn

# ─── Deployer (for badge minting — use a low-privilege key) ─
# In production, prefer a KMS-managed key or hardware wallet signer.
DEPLOYER_PRIVATE_KEY=0x...

# ─── Server ────────────────────────────────────────────────
PORT=3001
